<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_bulk_income_account" model="ir.ui.view">
        <field name="name">account.move.form.bulk.income.account</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="%(action_account_move_bulk_income_account_wizard)d"
                        type="action"
                        string="Update Income Account"
                        class="btn-secondary"
                        invisible="state != 'draft' or move_type != 'out_invoice'"/>
            </xpath>
        </field>
    </record>
</odoo>
