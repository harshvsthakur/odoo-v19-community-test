<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_move_bulk_income_account_wizard_form" model="ir.ui.view">
        <field name="name">account.move.bulk.income.account.wizard.form</field>
        <field name="model">account.move.bulk.income.account.wizard</field>
        <field name="arch" type="xml">
            <form>
                <field name="move_id" invisible="1"/>
                <group>
                    <field name="income_account_id"/>
                </group>
                <p class="text-muted">
                    This will overwrite the account on every line of this invoice.
                </p>
                <footer>
                    <button name="action_apply" type="object" string="Apply" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_account_move_bulk_income_account_wizard" model="ir.actions.act_window">
        <field name="name">Update Income Account</field>
        <field name="res_model">account.move.bulk.income.account.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_move_id': active_id}</field>
    </record>
</odoo>
